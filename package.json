{
  "name": "living-rewards",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "npm --workspace @living-rewards/web run dev",
    "dev:api": "npm --workspace @living-rewards/api run dev",
    "build": "npm-run-all build:web build:api",
    "build:web": "npm --workspace @living-rewards/web run build",
    "build:api": "npm --workspace @living-rewards/api run build",
    "start": "npm --workspace @living-rewards/api run start",
    "check": "npm-run-all check:web check:api",
    "check:web": "npm --workspace @living-rewards/web run check",
    "check:api": "npm --workspace @living-rewards/api run check",
    "test": "npm --workspace @living-rewards/web run test"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.4",
    "npm-run-all": "^4.1.5"
  }
}
