{
  "name": "@living-rewards/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DEMO_MODE=1 tsx src/index.ts",
    "build": "esbuild src/index.ts --platform=node --bundle --format=esm --target=node22 --legal-comments=none --outdir=dist --external:cookie-parser --external:cors --external:dotenv --external:express --external:helmet --external:jose --external:pg --external:zod",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jose": "^5.10.0",
    "pg": "^8.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/node": "20.16.11",
    "@types/pg": "^8.20.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
